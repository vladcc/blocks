{
	prog_options * context = (prog_options *)ctx;
	context->ignore_top = true;
}

static void help_ignore_top(const char * short_name, const char * long_name)
{
printf("%s|%s\n", short_name, long_name);
puts("Print only the body of the block. I.e. don't print the block name,");
puts("block start, and block end. All lines between and including the block");
puts("name and block open, as well as the line containing the block end are");
puts("ignored.");
puts("");
}

