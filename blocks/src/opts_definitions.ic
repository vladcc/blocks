// --match|-m
static const char match_opt_short = 'm';
static const char match_opt_long[] = "match";
static void handle_match(const char * opt, char * opt_arg, void * ctx)
{
	prog_options * context = (prog_options *)ctx;
	context->match = true;
	context->dont_match = false;
	context->match_dont_match = opt_arg;
	context->is_match_dont_match_regex = context->is_next_matcher_regex;
}

static void help_match(const char * short_name, const char * long_name)
{
printf("%s|%s <matcher>\n", short_name, long_name);
puts("Print only blocks in which at least one line matches <matcher>.");
puts("");
}

// --dont-match|-M
static const char dont_match_opt_short = 'M';
static const char dont_match_opt_long[] = "dont-match";
static void handle_dont_match(const char * opt, char * opt_arg, void * ctx)
{
	prog_options * context = (prog_options *)ctx;
	context->match = false;
	context->dont_match = true;
	context->match_dont_match = opt_arg;
	context->is_match_dont_match_regex = context->is_next_matcher_regex;
}

static void help_dont_match(const char * short_name, const char * long_name)
{
printf("%s|%s <matcher>\n", short_name, long_name);
puts("Print only blocks in which no line matches <matcher>.");
puts("");
}

