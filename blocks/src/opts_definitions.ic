	context->block_start = opt_arg;
	context->is_block_start_regex = context->is_next_matcher_regex;
}

static void help_block_start(const char * short_name, const char * long_name)
{
printf("%s|%s <matcher>\n", short_name, long_name);
printf(
"Set <matcher> as the open block symbol. Default is '%s'\n",
defaults.block_open
);
puts("");
}

